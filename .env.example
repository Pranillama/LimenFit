# consumed by lib/supabase/* (T2)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
NEXT_PUBLIC_SUPABASE_URL=

# consumed by lib/supabase/* (T2)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# server-only; consumed by lib/supabase/server.ts and pg_cron-adjacent helpers (T2/T3)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
SUPABASE_SERVICE_ROLE_KEY=

# canonical absolute URL for robots.txt / sitemap.xml — no trailing slash
# local: http://localhost:3000 | Vercel: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# optional; defaults to development
NODE_ENV=
