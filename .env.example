# consumed by lib/supabase/* (T2)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
NEXT_PUBLIC_SUPABASE_URL=

# consumed by lib/supabase/* (T2)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# server-only; consumed by lib/supabase/server.ts and pg_cron-adjacent helpers (T2/T3)
# local: copy from `pnpm db:start` output | Vercel: set in project env vars (Production + Preview)
SUPABASE_SERVICE_ROLE_KEY=

# canonical absolute URL for robots.txt / sitemap.xml — no trailing slash
# local: http://localhost:3000 | Vercel: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# optional; defaults to development
# NODE_ENV=

# Optional AI entries below — leave the lines commented out (or omit entirely) to disable.
# Blank values (e.g. `KEY=`) are treated as unset.

# server-only; consumed by lib/ai/* — required only when the AI assistant flag is on
# local: get a key from https://aistudio.google.com/apikey | Vercel: set in project env vars (Production + Preview)
# GOOGLE_GENAI_API_KEY=

# feature flag for the AI assistant (/ask) — accepts "1"/"true" (enable) or "0"/"false" (disable); defaults to off
# local: omit to keep the assistant disabled | Vercel: set to "1" to enable
# LIMENFIT_FEATURE_AI_ASSISTANT=

# when "1"/"true", ai_chat_logs stores raw prompt text alongside the hash — intended for early-rollout debugging only
# local: omit | Vercel: keep off in production once the assistant is stable
# LIMENFIT_AI_LOG_PROMPT_TEXT=

# reserved for the future Redis-backed rate limiter (not consumed in this ticket)
# local: omit | Vercel: set when wiring up Upstash/Redis for AI rate limiting
# REDIS_URL=
